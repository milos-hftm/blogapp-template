{
  "name": "blogapp-template",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch",
    "test:ci": "ng test --no-watch --coverage",
    "lint": "ng lint",
    "format": "npx prettier --write ./src/app/*",
    "prepare": "husky",
    "analyze:deps:all": "madge src/main.ts --ts-config tsconfig.json --image ./deps/blogapp-template/_all.png",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "serve:e2e": "http-server dist/app/browser -p 4200 --silent -c-1"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "lint-staged": {
    "*.{ts,js,html}": "eslint --cache --fix",
    "*.{ts,js,html,css,scss,less,md}": "prettier --write"
  },
  "private": true,
  "packageManager": "npm@11.3.0",
  "overrides": {
    "@angular-devkit/architect": "^0.2200.0",
    "@angular-devkit/core": "^22.0.0",
    "@angular-devkit/schematics": "^22.0.0"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/schematics": "21.4.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.8",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.0.3",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.8"
  }
}
